---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Navios" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen items-center justify-center bg-bg">
    <slot />
  </body>
</html>
